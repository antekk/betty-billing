{
  "name": "betty-billing",
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@next/eslint-plugin-next": "^15.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-import-x": "^4.4.0",
    "eslint-plugin-prettier": "^5.2.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.0",
    "typescript-eslint": "^8.15.0",
    "vitest": "^4.1.2"
  },
  "private": true,
  "scripts": {
    "dev:api": "bun run --filter @betty/api dev",
    "typecheck": "bun run --filter '*' typecheck",
    "db:generate": "bun run --filter @betty/api db:generate",
    "db:migrate": "bun run --filter @betty/api db:migrate",
    "db:seed": "bun run --filter @betty/api db:seed",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun run --filter '*' test",
    "check": "bun run lint && bun run format:check && bun run typecheck"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
